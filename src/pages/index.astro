---
import "../styles/base.css";
---

<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>xing's blog</title>
    </head>
    <body>
        <div id="home">
            <!-- 导航栏 -->
            <div id="header">
                <div id="blogTitle">
                    <a id="lnkBlogTitle" href="/">xing's blog</a>
                </div>
                <div id="navigator">
                    <ul id="navList">
                        <li><a id="blog_nav_sitehome" class="menu" href="#">博客园</a></li>
                        <li><a id="blog_nav_myhome" class="menu" href="/">首页</a></li>
                        <li><a id="blog_nav_newpost" class="menu" href="#">新随笔</a></li>
                        <li><a id="blog_nav_contact" class="menu" href="#">联系</a></li>
                        <li><a id="blog_nav_rss" class="menu" href="#">订阅</a></li>
                        <li><a id="blog_nav_admin" class="menu" href="#">管理</a></li>
                    </ul>
                </div>
            </div>

            <!-- 主要内容区域 -->
            <div id="main">
                <div id="mainContent">
                    <div class="forFlow">
                        <!-- 文章列表 -->
                        <div class="day">
                            <div class="dayTitle">
                                <a href="#">2024年7月10日</a>
                            </div>

                            <div class="post">
                                <div class="postTitle">
                                    <a class="postTitle2" href="#">文章标题示例</a>
                                </div>
                                <div class="postCon">
                                    <div class="c_b_p_desc">
                                        摘要: 这里是文章摘要内容...
                                        <a href="#" class="c_b_p_desc_readmore">阅读全文</a>
                                    </div>
                                </div>
                                <div class="clear"></div>
                                <div class="postDesc"> posted @ 2024-07-10 14:30 xing 阅读(123) 评论(2) 推荐(0) 编辑</div>
                            </div>

                            <div class="post">
                                <div class="postTitle">
                                    <a class="postTitle2" href="#">另一篇文章标题</a>
                                </div>
                                <div class="postCon">
                                    <div class="c_b_p_desc">
                                        摘要: 这里是另一篇文章的摘要内容...
                                        <a href="#" class="c_b_p_desc_readmore">阅读全文</a>
                                    </div>
                                </div>
                                <div class="clear"></div>
                                <div class="postDesc"> posted @ 2024-07-09 16:20 xing 阅读(89) 评论(0) 推荐(1) 编辑</div>
                            </div>
                        </div>

                        <div class="day">
                            <div class="dayTitle">
                                <a href="#">2024年7月7日</a>
                            </div>

                            <div class="post">
                                <div class="postTitle">
                                    <a class="postTitle2" href="#">技术文章标题</a>
                                </div>
                                <div class="postCon">
                                    <div class="c_b_p_desc">
                                        摘要: 这里是技术文章的摘要内容...
                                        <a href="#" class="c_b_p_desc_readmore">阅读全文</a>
                                    </div>
                                </div>
                                <div class="clear"></div>
                                <div class="postDesc"> posted @ 2024-07-07 14:00 xing 阅读(234) 评论(5) 推荐(3) 编辑</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 侧边栏 -->
                <div id="sideBar">
                    <div id="sideBarMain">
                        <!-- 个人信息 -->
                        <div id="blog-news">
                            <div id="blog-news-block">
                                <div id="blog-news-avatar">
                                    <div id="blog-news-avatar-img"></div>
                                </div>
                                <div id="profile_block">
                                    昵称：<a href="#">xing</a><br />
                                    园龄：<a href="#">1年</a><br />
                                    粉丝：<a href="#">15</a><br />
                                    关注：<a href="#">8</a>
                                </div>
                            </div>
                        </div>

                        <!-- 公告 -->
                        <div id="calendar" class="newsItem">
                            <div class="catListTitle">公告</div>
                            <div id="blog-calendar">
                                <p>这里是公告内容...</p>
                            </div>
                        </div>

                        <!-- 分类 -->
                        <div id="sideBarCategory" class="newsItem">
                            <div class="catListTitle">分类</div>
                            <ul>
                                <li><a href="#">分类名称 (15)</a></li>
                                <li><a href="#">分类名称 (8)</a></li>
                                <li><a href="#">分类名称 (5)</a></li>
                                <li><a href="#">分类名称 (3)</a></li>
                                <li><a href="#">分类名称 (7)</a></li>
                            </ul>
                        </div>

                        <!-- 最新评论 -->
                        <div id="recent_comments_wrap" class="newsItem">
                            <div class="catListTitle">最新评论</div>
                            <ul class="recent_comments">
                                <li><a href="#">博主</a>: 这是评论内容...</li>
                                <li><a href="#">访客</a>: 这是评论内容...</li>
                                <li><a href="#">网友</a>: 这是评论内容...</li>
                            </ul>
                        </div>

                        <!-- 阅读排行 -->
                        <div id="sideBarReading" class="newsItem">
                            <div class="catListTitle">阅读排行</div>
                            <ul>
                                <li><a href="#">文章标题1</a></li>
                                <li><a href="#">文章标题2</a></li>
                                <li><a href="#">文章标题3</a></li>
                                <li><a href="#">文章标题4</a></li>
                                <li><a href="#">文章标题5</a></li>
                            </ul>
                        </div>

                        <!-- 推荐排行 -->
                        <div id="sideBarRecommended" class="newsItem">
                            <div class="catListTitle">推荐排行</div>
                            <ul>
                                <li><a href="#">文章标题1</a></li>
                                <li><a href="#">文章标题2</a></li>
                                <li><a href="#">文章标题3</a></li>
                                <li><a href="#">文章标题4</a></li>
                                <li><a href="#">文章标题5</a></li>
                            </ul>
                        </div>

                        <!-- 标签 -->
                        <div id="sideBarTags" class="newsItem">
                            <div class="catListTitle">标签</div>
                            <div id="tag_cloud">
                                <a href="#">标签1</a>
                                <a href="#">标签2</a>
                                <a href="#">标签3</a>
                                <a href="#">标签4</a>
                                <a href="#">标签5</a>
                                <a href="#">标签6</a>
                                <a href="#">标签7</a>
                                <a href="#">标签8</a>
                                <a href="#">标签9</a>
                            </div>
                        </div>

                        <!-- 友情链接 -->
                        <div id="blog-sidecolumn" class="newsItem">
                            <div class="catListTitle">友情链接</div>
                            <ul>
                                <li><a href="#">链接1</a></li>
                                <li><a href="#">链接2</a></li>
                                <li><a href="#">链接3</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="clear"></div>
            </div>

            <!-- 页脚 -->
            <div id="footer">
                Copyright © 2024 xing<br />
                Powered by Astro
            </div>
        </div>
    </body>
</html>
