---
import MainLayout from "../layouts/MainLayout.astro";

const talkModules = import.meta.glob('../small_talk/*.md', { eager: true });
const talkEntries = Object.values(talkModules)
    .sort(function(a, b) { return new Date(b.frontmatter.date) - new Date(a.frontmatter.date); });

const learnModules = import.meta.glob('../learn/*.md', { eager: true });
const learnEntries = Object.values(learnModules)
    .sort(function(a, b) { return new Date(b.frontmatter.date) - new Date(a.frontmatter.date); });

const lifeModules = import.meta.glob('../life/*.md', { eager: true });
const lifeEntries = Object.values(lifeModules)
    .sort(function(a, b) { return new Date(b.frontmatter.date) - new Date(a.frontmatter.date); });

const othModules = import.meta.glob('../oth/*.md', { eager: true });
const othEntries = Object.values(othModules)
    .sort(function(a, b) { return new Date(b.frontmatter.date) - new Date(a.frontmatter.date); });


---

<MainLayout title="xing's blog">
    <!-- 每日一图 -->
    <div id="section-daily" class="section-content" style="display:none">
        <div id="daily-image-view" class="daily-view-init">
            <div class="daily-image-empty">加载中...</div>
        </div>
    </div>

    <!-- xing的碎碎念 — 气泡框居中排列 -->
    <div id="section-small_talk" class="section-content">
        <div class="small-talk-wrapper">
            <h2 class="small-talk-heading">xing的碎碎念</h2>
            <div class="small-talk-bubbles" id="small-talk-bubbles">
                {talkEntries.length === 0 && (
                    <div class="talk-bubble">
                        <p class="talk-bubble-text">暂无内容</p>
                    </div>
                )}
                {talkEntries.map(entry => (
                    <div class={"talk-bubble" + (entry.frontmatter.type ? " " + entry.frontmatter.type : "")}>
                        <div class="talk-bubble-text"><entry.Content /></div>
                        <div class="talk-bubble-time">{entry.frontmatter.date}</div>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <!-- 学习杂记 -->
    <div id="section-learn" class="section-content" style="display:none">
        <div class="category-content">
            <h2 class="category-title">学习杂记</h2>
            <div class="learn-cards-grid">
                {learnEntries.length === 0 && (
                    <div class="category-empty"><p>暂无内容，敬请期待</p></div>
                )}
                {learnEntries.map(entry => (
                    <a href="javascript:void(0)" class="learn-card" data-path={"/learn/" + entry.frontmatter.slug} onclick="openArticle(this.dataset.path)">
                        <div class="learn-card-category">{entry.frontmatter.category}</div>
                        <h3 class="learn-card-title">{entry.frontmatter.title}</h3>
                        <p class="learn-card-excerpt">{entry.frontmatter.excerpt}</p>
                        <div class="learn-card-footer">
                            <span class="learn-card-date">{entry.frontmatter.date}</span>
                            <span class="learn-card-read">阅读全文 &rarr;</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>

    <!-- 闲鱼生存日记 -->
    <div id="section-life" class="section-content" style="display:none">
        <div class="category-content">
            <h2 class="category-title">闲鱼生存日记</h2>
            {lifeEntries.length === 0 ? (
                <div class="category-empty"><p>暂无内容，敬请期待</p></div>
            ) : (
                <div class="learn-cards-grid">
                    {lifeEntries.map(entry => (
                        <a href="javascript:void(0)" class="learn-card" data-path={"/life/" + entry.frontmatter.slug} onclick="openArticle(this.dataset.path)">
                            <div class="learn-card-category">{entry.frontmatter.category}</div>
                            <h3 class="learn-card-title">{entry.frontmatter.title}</h3>
                            <p class="learn-card-excerpt">{entry.frontmatter.excerpt}</p>
                            <div class="learn-card-footer">
                                <span class="learn-card-date">{entry.frontmatter.date}</span>
                                <span class="learn-card-read">阅读全文 &rarr;</span>
                            </div>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </div>

    <!-- 杂言小计 -->
    <div id="section-oth" class="section-content" style="display:none">
        <div class="category-content">
            <h2 class="category-title">杂言小计</h2>
            {othEntries.length === 0 ? (
                <div class="category-empty"><p>暂无内容，敬请期待</p></div>
            ) : (
                <div class="learn-cards-grid">
                    {othEntries.map(entry => (
                        <a href="javascript:void(0)" class="learn-card" data-path={"/oth/" + entry.frontmatter.slug} onclick="openArticle(this.dataset.path)">
                            <div class="learn-card-category">{entry.frontmatter.category}</div>
                            <h3 class="learn-card-title">{entry.frontmatter.title}</h3>
                            <p class="learn-card-excerpt">{entry.frontmatter.excerpt}</p>
                            <div class="learn-card-footer">
                                <span class="learn-card-date">{entry.frontmatter.date}</span>
                                <span class="learn-card-read">阅读全文 &rarr;</span>
                            </div>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </div>
</MainLayout>

